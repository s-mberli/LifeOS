# LifeOS Environment Variables
# Copy this file to .env and fill in your keys

# General
LLM_PROVIDER_ORDER=azure,gemini,openrouter

# Azure OpenAI
AZURE_OPENAI_ENDPOINT="https://your-resource-name.openai.azure.com/openai/v1/"
AZURE_EXISTING_AIPROJECT_ENDPOINT="https://your-resource-name.openai.azure.com/openai/v1/"
AZURE_OPENAI_API_KEY="your-azure-key"
AZURE_OPENAI_DEPLOYMENT="gpt-4o"
AZURE_OPENAI_MAX_TOKENS=1200

# Gemini
GEMINI_API_KEY="your-gemini-key"
GEMINI_MODEL="gemini-2.5-flash"
GEMINI_MAX_TOKENS=1200

# OpenRouter
OPENROUTER_API_KEY="sk-or-v1-..."
OPENROUTER_MODEL="google/gemini-2.5-flash"
OPENROUTER_MAX_TOKENS=1200

# GitHub (required for Hermes autonomous PR workflow)
GITHUB_TOKEN="ghp_your-github-pat-here"

# ElevenLabs (TTS & Voice Personas)
ELEVENLABS_API_KEY="your_api_key_here"
ELEVENLABS_DEFAULT_VOICE_ID="your_default_voice_id"

# Hermes Autonomous Agent (optional — only needed for weekly self-improvement loop)
# Point these to your local Hermes agent installation
HERMES_BIN="/path/to/hermes-agent/venv/bin/python"
HERMES_SCRIPT="/path/to/hermes-agent/hermes"

