# ============================================================
# LifeOS .gitignore — Safe for public GitHub repo
# ============================================================

# Environment & Secrets
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production
.env.staging

# Private/sensitive data
data/private/
src/data/

# Logs & generated outputs (too large for git)
logs/
outputs/
data/tts_cache/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
ENV/
env/

# Testing artifacts
.pytest_cache/
.coverage
htmlcov/

# Streamlit secrets
.streamlit/secrets.toml

# macOS
.DS_Store
.AppleDouble
Thumbs.db

# Scratch / one-off dev scripts (never commit these)
scratch/

# SQLite indexes (rebuilt at startup)
indexes/*.db
src/indexes/*.db

# Raw transcripts (can be very large)
**/raw/

# Raw inbox — unprocessed personal input
data/inbox/raw/
data/inbox/processed/raw/
data/inbox/imports/
data/inbox/voice/

# Hermes weekly output (local only — never public)
data/inbox/proposals/
data/inbox/content_drafts/

# Personal config (profile.yml contains real personal info)
# Use profile.example.yml as the template instead
config/profile.yml
config/models.yml
config/privacy.yml
config/domains.yaml

# Exclude all markdown notes and transcripts
data/knowledge/**/*.md
data/experts/**/*.md
data/business/**/*.md
data/career/**/*.md
data/inbox/**/*.md

# Scratch tools in root
fix_*.py
format_*.py
scratch_*.py

# ============================================================
# Explicitly KEEP these (force-include reusable system files)
# ============================================================
!modes/
!templates/
!scripts/
!config/profile.example.yml
!config/models.example.yml
!config/domains.example.yaml
!config/domain_map.yaml
!.env.example
!README.md
!AGENTS.md
!data/README.md
!data/knowledge/creator-profiles/README.md
!**/example-*.md
!**/.gitkeep


# LaunchAgents
*.plist
!*.example.plist
